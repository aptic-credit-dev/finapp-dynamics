# Finapp Dynamics — example environment.
# Copy to `.env` and fill in locally. NEVER commit a real `.env` (ADR-009: no raw key storage).

# PostgreSQL 16. Absent => the DB integration lane is skipped (smoke lane still runs).
DATABASE_URL=postgres://finapp:finapp@localhost:5432/finapp_dev

# Three roles, and the difference between them is load-bearing (docs/07-engineering/DATABASE_CONVENTIONS.md):
#
#   superuser   Bypasses RLS COMPLETELY — FORCE does not constrain it. Never connect the app as one.
#   owner       Owns the tables; runs migrations. Non-superuser, so FORCE binds it.
#   app         Neither superuser nor owner. What the API connects as.
#
# Both roles must be NOBYPASSRLS: a role with BYPASSRLS ignores every tenant_isolation policy.
DATABASE_OWNER_ROLE=finapp_owner
DATABASE_APP_ROLE=finapp_app

NODE_ENV=development
API_PORT=3000
