# Finapp Dynamics — monorepo (TypeScript / NestJS / PostgreSQL 16)

# Dependencies
node_modules/
.pnp
.pnp.js
.yarn/cache
.yarn/unplugged
.yarn/install-state.gz

# Build output
dist/
build/
out/
*.tsbuildinfo

# `build/` above matches a directory named "build" at ANY depth, which silently swallowed
# docs/build/ — the stage build records. Those are deliverables, not build output.
!docs/build/
!docs/build/**

# TypeScript project references / declaration maps
*.js.map
*.d.ts.map

# Test & coverage
coverage/
.nyc_output/
junit.xml
test-results/

# Caches
.npm/
.eslintcache
.cache/
.turbo/
.nest/

# Environment & secrets
# ADR-009: no raw key storage — references only. Never commit real credentials.
.env
.env.*
!.env.example
*.pem
*.key
*.p12
*.pfx
secrets.json
*.secret.yaml
!*secret*.example.yaml

# Local database / migration scratch
*.sqlite
*.sqlite3
pgdata/
docker-compose.override.yml

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# IDE / editors
.vscode/*
!.vscode/extensions.json
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db
Desktop.ini

# Agent scratch
.claude/settings.local.json
