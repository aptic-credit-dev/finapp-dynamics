{
  // ESLint-only project. The build tsconfig deliberately excludes `test/**` so the API's build graph does
  // not depend on the test-runner tool (see tsconfig.json). But type-aware linting still needs a program
  // that INCLUDES the integration spec, so this config exists purely for eslint's parserOptions.project —
  // it is referenced by eslint.config.mjs, never by `tsc --build`, and emits nothing.
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": ".",
    "composite": false,
    "noEmit": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true
  },
  "include": ["src/**/*.ts", "test/**/*.ts"],
  "references": [
    { "path": "../../packages/kernel" },
    { "path": "../../packages/contracts" },
    { "path": "../../packages/m01-tenant" },
    { "path": "../../packages/m02-identity" },
    { "path": "../../tools/test-runner" }
  ]
}
